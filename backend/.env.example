# AWS Configuration
AWS_REGION=us-east-1

# Cognito Configuration - Get these from your AWS Cognito User Pool
COGNITO_USER_POOL_ID=your-cognito-user-pool-id
COGNITO_CLIENT_ID=your-cognito-client-id

# DynamoDB Configuration - Get from your DynamoDB table
TABLE_NAME=your-dynamodb-table-name

# S3 Configuration - Get from your S3 bucket
UPLOAD_BUCKET=your-s3-bucket-name

# SNS Configuration - Get from your SNS topic
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:your-topic-name

# Application Configuration
PORT=3000

# JWT Configuration (optional - has a default fallback, but recommended to set for production)
JWT_SECRET=your-jwt-secret-key-change-in-production
